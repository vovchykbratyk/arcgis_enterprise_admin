{
  "connection": "my_connection",
  "portal_home_url": "https://my.site/portal",

  "inactivity": {
    "demote_after_days": 35,
    "warning_days": [15, 20, 28, 29, 30, 31, 32, 33, 34],
    "treat_never_logged_in_as_days_inactive": 35
  },

  "demotion": {
    "viewer_role": "viewer",
    "viewer_user_license_type_id": "viewerUT"
  },

  "exclusions": {
    "skip_usernames": [
      "admin",
      "arcgis",
      "svc_portal_automation",
      "cert_admin01",
      "cert_admin02"
    ],
    "skip_roles": ["org_admin"]
  },

  "storage": {
    "sqlite_db_path": "inactive_users.db"
  },

  "email": {
    "smtp_json_path": "smtp.json"
  }
}